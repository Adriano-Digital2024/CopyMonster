# Environment variables for Docker.
# Copy this file to .env and fill in your actual values.

# Supabase
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sua-chave-aqui
VITE_SUPABASE_PROJECT_ID=seu-project-id

# Stripe (Public Key - use test key for development)
# Get your keys at: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# ---------------------------------------------------------------------------
# AI providers (BYO LLM)
# ---------------------------------------------------------------------------
# These are SERVER-SIDE secrets and must NOT be exposed to the browser.
# Configure them in Supabase → Edge Function Secrets, not in this file.
# Listed here only for discoverability.
#
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=
# MISTRAL_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434

# ---------------------------------------------------------------------------
# Optional integrations (server-side, set in Supabase Edge Function Secrets)
# ---------------------------------------------------------------------------
# STRIPE_SECRET_KEY=
# META_APP_ID=
# META_APP_SECRET=
# META_WEBHOOK_VERIFY_TOKEN=
# SENDER_API_KEY=
# MAUTIC_BASE_URL=https://mautic.integridadedigital.com.br
# MAUTIC_CLIENT_ID=
# MAUTIC_CLIENT_SECRET=
# SITE_URL=https://copymonster.me
